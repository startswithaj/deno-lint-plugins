{
  "compilerOptions": {
    "strict": true
  },
  "imports": {
    "@std/assert": "jsr:@std/assert@^1",
    "@std/expect": "jsr:@std/expect@^1.0.18",
    "@std/testing": "jsr:@std/testing@^1.0.17"
  },
  "tasks": {
    "lint": "deno lint",
    "fmt": "deno fmt",
    "fmt:check": "deno fmt --check",
    "check": "deno check src/",
    "test": "deno test --allow-read --allow-env",
    "check:all": "deno fmt --check && deno lint && deno check src/ && deno task test"
  },
  "lint": {
    "rules": {
      "tags": ["recommended"]
    },
    "exclude": [
      "**/coverage/",
      "**/node_modules/"
    ]
  },
  "fmt": {
    "exclude": [
      "**/coverage/",
      "**/node_modules/"
    ]
  }
}
